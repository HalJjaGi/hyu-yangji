# 환경 변수 설정 파일

# 서버 설정
PORT=3003
NODE_ENV=development
FRONTEND_URL=http://localhost:8002

# 데이터베이스 설정
MONGODB_URI=mongodb://localhost:27017/hyu_yangji
# 또는 MongoDB Atlas Cloud 사용:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hyu_yangji?retryWrites=true&w=majority

# JWT 설정
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API 키 설정
# 서울열린데이터광장 API 키
# 발급 주소: https://data.seoul.go.kr/
SEOUL_API_KEY=5a6c747647686b61313132754a454f70

# 한국관광공사 API 키
# 발급 주소: https://api.visitkorea.or.kr/
TOURISM_API_KEY=your-actual-tourism-api-key

# NOTE: 위 SEOUL_API_KEY는 예시 키입니다.
# 실제로는 서울열린데이터광장에서 발급받은 키를 사용해주세요.
# TOURISM_API_KEY는 한국관광공사에서 발급받아야 합니다.

# 관리자 설정
ADMIN_EMAIL=admin@hyu-yangji.com
ADMIN_PASSWORD=change-this-password

# 파일 업로드 설정
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_PATH=uploads/

# 로그 레벨
LOG_LEVEL=info

# 보안 설정
CORS_ORIGIN=http://localhost:8002
RATE_LIMIT_WINDOW=900000  # 15분
RATE_LIMIT_MAX=100  # 15분당 최대 100개 요청

# 모니터링 설정
SENTRY_DSN=your-sentry-dsn
HEALTH_CHECK_INTERVAL=30000  # 30초

# 클라우드 설정
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# 이메일 설정 (선택사항)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@hyu-yangji.com