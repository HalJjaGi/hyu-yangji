# 데이터베이스 설정
DATABASE_URL=postgresql://username:password@localhost:5432/hyu_yangji

# Redis 설정
REDIS_URL=redis://localhost:6379

# 서버 설정
PORT=3000
NODE_ENV=development

# JWT 설정 (나중에 인증 기능 추가 시)
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# CORS 설정
ALLOWED_ORIGINS=http://localhost:3000,https://hyu-yangji.pages.dev

# 로깅 설정
LOG_LEVEL=info
LOG_DIR=./logs

# 파일 업로드 설정
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# API 레이트 리밋
RATE_LIMIT_WINDOW_MS=900000  # 15분
RATE_LIMIT_MAX_REQUESTS=100

# 외부 API 키 (나중에 데이터 수집 시)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# 크롤링 설정
CRAWLING_DELAY_MS=1000
CRAWLING_USER_AGENT=HYU양지-Bot/1.0
CRAWLING_MAX_RETRIES=3

# 모니터링 설정
SENTRY_DSN=your-sentry-dsn
HEALTH_CHECK_INTERVAL=30000  # 30초